{
  "name": "prism-parking",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@capacitor/android": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/ios": "^8.2.0",
    "@react-google-maps/api": "^2.20.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "firebase": "^12.9.0",
    "framer-motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router": "^7.12.0",
    "react-router-dom": "^7.13.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4000",
    "start": "vite --host 0.0.0.0 --port 4000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4000",
    "dev:web": "vite --host 0.0.0.0 --port 4000",
    "build:web": "vite build",
    "clean:web": "rm -rf dist",
    "clean:android": "rm -rf android/.gradle android/app/build",
    "clean:ios": "rm -rf ios/App/build",
    "clean:native": "npm run clean:android && npm run clean:ios",
    "clean:all": "rm -rf dist android/.gradle android/app/build ios/App/build",
    "reset:deps": "rm -rf node_modules package-lock.json && npm install",
    "reset:all": "rm -rf node_modules dist android/.gradle android/app/build ios/App/build && npm install",
    "run:android": "npm run build:web && npx cap sync android && npx cap run android",
    "run:ios": "npm run build:web && npx cap sync ios && npx cap run ios",
    "test:all": "npm run build:web && npx cap sync && npx cap run android && npx cap run ios"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.22",
    "eslint-config-react-app": "^7.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
